// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  AWAITING_PAYMENT
  PAYMENT_SUBMITTED
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum PaymentMethod {
  BITCOIN
  ETHEREUM
  USDT_TRC20
  LITECOIN
  BUSD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum EventType {
  MEET_AND_GREET
  VIDEO_CALL
  BIRTHDAY_SHOUTOUT
  VIP_DINNER
  LIVE_APPEARANCE
  PRIVATE_CONCERT
  PHOTO_SESSION
}

enum CelebCategory {
  MUSIC
  ACTOR
  INFLUENCER
  ATHLETE
  COMEDIAN
  DJ
  PRESENTER
  POLITICIAN
  ENTREPRENEUR
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          Role      @default(USER)
  suspended     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]
  notifications Notification[]
  emailLogs     EmailLog[]

  @@map("users")
}

// ─────────────────────────────────────────────
// NEXTAUTH MODELS
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// CELEBRITY
// ─────────────────────────────────────────────

model Celebrity {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  category    CelebCategory
  bio         String        @db.Text
  location    String?
  nationality String?
  yearsActive String?
  verified    Boolean       @default(false)
  featured    Boolean       @default(false)
  active      Boolean       @default(true)
  basePrice   Float
  image       String?
  coverImage  String?
  rating      Float         @default(0)
  reviewCount Int           @default(0)
  gallery     String[]      @default([])
  socialLinks Json?
  tags        String[]      @default([])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  packages  Package[]
  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]
  events    Event[]

  @@map("celebrities")
}

// ─────────────────────────────────────────────
// PACKAGE
// ─────────────────────────────────────────────

model Package {
  id          String    @id @default(cuid())
  celebrityId String
  name        String
  description String    @db.Text
  eventType   EventType
  duration    Int       // in minutes
  price       Float
  maxGuests   Int       @default(1)
  includes    String[]  @default([])
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  celebrity Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Cascade)
  bookings  Booking[]

  @@map("packages")
}

// ─────────────────────────────────────────────
// EVENT
// ─────────────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  celebrityId String
  title       String
  description String    @db.Text
  eventType   String    @default("MEET_AND_GREET")
  date        DateTime?
  isTimedEvent Boolean  @default(false)
  duration    Int       // in minutes
  location    String?
  isOnline    Boolean   @default(false)
  capacity    Int       @default(1)
  booked      Int       @default(0)
  price       Float
  image       String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  celebrity Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Cascade)
  bookings  Booking[]

  @@map("events")
}

// ─────────────────────────────────────────────
// BOOKING
// ─────────────────────────────────────────────

model Booking {
  id                  String        @id @default(cuid())
  reference           String        @unique @default(cuid())
  userId              String
  celebrityId         String
  packageId           String?
  eventId             String?
  status              BookingStatus @default(PENDING)
  eventType           EventType
  eventDate           DateTime
  duration            Int           // in minutes
  location            String?
  isOnline            Boolean       @default(false)
  specialRequirements String?       @db.Text
  guestCount          Int           @default(1)
  totalAmount         Float
  paymentMethod       PaymentMethod?
  adminNotes          String?       @db.Text
  cancelledAt         DateTime?
  cancelReason        String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Contact info (in case user not logged in or guest books)
  contactName  String?
  contactEmail String?
  contactPhone String?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  celebrity Celebrity @relation(fields: [celebrityId], references: [id])
  package   Package?  @relation(fields: [packageId], references: [id])
  event     Event?    @relation(fields: [eventId], references: [id])
  payment   Payment?
  documents Document[]

  @@map("bookings")
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  method        PaymentMethod
  amount        Float
  currency      String        @default("USD")
  walletAddress String?
  proofUrl      String?
  txHash        String?
  bankRef       String?
  status        PaymentStatus @default(PENDING)
  verifiedAt    DateTime?
  verifiedBy    String?
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─────────────────────────────────────────────
// CRYPTO WALLET
// ─────────────────────────────────────────────

model CryptoWallet {
  id         String        @id @default(cuid())
  coin       PaymentMethod
  label      String
  address    String
  qrCodeUrl  String?
  network    String?
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("crypto_wallets")
}

// ─────────────────────────────────────────────
// BANK ACCOUNT
// ─────────────────────────────────────────────

model BankAccount {
  id            String   @id @default(cuid())
  bankName      String
  accountName   String
  accountNumber String
  routingNumber String?
  swiftCode     String?
  iban          String?
  currency      String   @default("USD")
  country       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("bank_accounts")
}

// ─────────────────────────────────────────────
// DOCUMENT / FILE UPLOAD
// ─────────────────────────────────────────────

model Document {
  id         String   @id @default(cuid())
  bookingId  String
  name       String
  url        String
  size       Int
  mimeType   String
  uploadedAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ─────────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────────

model Review {
  id          String    @id @default(cuid())
  userId      String
  celebrityId String
  rating      Int       // 1-5
  comment     String    @db.Text
  approved    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  celebrity Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ─────────────────────────────────────────────
// FAVORITE
// ─────────────────────────────────────────────

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  celebrityId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  celebrity Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Cascade)

  @@unique([userId, celebrityId])
  @@map("favorites")
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────────
// EMAIL LOG
// ─────────────────────────────────────────────

model EmailLog {
  id           String   @id @default(cuid())
  userId       String?
  to           String
  subject      String
  templateName String?
  status       String   @default("sent")
  error        String?
  sentAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("email_logs")
}

// ─────────────────────────────────────────────
// ADMIN LOG
// ─────────────────────────────────────────────

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  targetId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("admin_logs")
}

// ─────────────────────────────────────────────
// NEWSLETTER
// ─────────────────────────────────────────────

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
  active       Boolean  @default(true)

  @@map("newsletter_subscribers")
}

// ─────────────────────────────────────────────
// SITE SETTINGS
// ─────────────────────────────────────────────

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}
